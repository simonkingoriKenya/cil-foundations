# Email Configuration
# Copy this file to .env.local and fill in your SMTP credentials

# SMTP Server Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Sender Email Address
SMTP_FROM_EMAIL=noreply@castleworks.co.ke

# Note: For development, create .env.local with your actual credentials
# For production (Netlify), add these as environment variables in the dashboard
